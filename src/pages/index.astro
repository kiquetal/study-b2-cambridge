---
import Layout from '../layouts/Layout.astro';
import StudyForm from '../components/StudyForm';
import Dashboard from '../components/Dashboard';
import RecentSessions from '../components/RecentSessions';
---

<Layout title="B2 Cambridge Study Tracker">
  <!-- Left Side: Navigation & Form -->
  <section class="w-1/2 flex flex-col border-r border-primary/20 bg-black/40 overflow-hidden">
    <!-- Tab Navigation -->
    <div class="flex border-b border-primary/20 bg-background-dark/60">
      <button class="tab-btn flex-1 px-6 py-3 text-xs font-bold uppercase tracking-widest text-primary border-b-2 border-primary" data-tab="add">
        <span class="material-symbols-outlined text-sm mr-2 inline-block align-middle">add_circle</span>
        Add Session
      </button>
      <button class="tab-btn flex-1 px-6 py-3 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors" data-tab="dashboard">
        <span class="material-symbols-outlined text-sm mr-2 inline-block align-middle">dashboard</span>
        Dashboard
      </button>
      <button class="tab-btn flex-1 px-6 py-3 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors" data-tab="history">
        <span class="material-symbols-outlined text-sm mr-2 inline-block align-middle">history</span>
        History
      </button>
    </div>

    <!-- Tab Content -->
    <div class="flex-1 overflow-y-auto custom-scrollbar p-8">
      <!-- Add Session Tab -->
      <div id="tab-add" class="tab-content">
        <div class="mb-6">
          <div class="flex items-center gap-2 mb-4 text-primary">
            <span class="material-symbols-outlined text-sm">assignment</span>
            <h3 class="text-xs font-bold uppercase tracking-[0.2em]">Study Session Entry</h3>
          </div>
          <h1 class="text-2xl font-bold text-slate-100 mb-2 leading-tight">
            Log Your <span class="text-primary neon-glow">Learning Progress</span>
          </h1>
          <p class="text-sm text-slate-400">Track your B2 Cambridge preparation with detailed session records.</p>
        </div>
        <StudyForm client:load />
        <div class="mt-8 pt-6 border-t border-primary/10">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-xs text-primary">monitoring</span>
            <span class="text-[10px] uppercase tracking-widest font-bold text-primary">Session Telemetry</span>
          </div>
          <div class="font-mono text-[11px] text-primary/40 space-y-1">
            <div>[SYSTEM] Database connection active...</div>
            <div>[TRACKER] Spaced repetition engine online...</div>
            <div>[TRACKER] Review intervals: 1, 3, 7, 14, 30 days</div>
          </div>
        </div>
      </div>

      <!-- Dashboard Tab -->
      <div id="tab-dashboard" class="tab-content hidden">
        <Dashboard client:load />
      </div>

      <!-- History Tab -->
      <div id="tab-history" class="tab-content hidden">
        <RecentSessions client:load />
      </div>
    </div>
  </section>

  <!-- Right Side: Live Preview -->
  <section class="w-1/2 flex flex-col bg-black relative">
    <div class="absolute top-4 right-6 z-10">
      <div class="flex items-center gap-2 px-3 py-1 bg-primary/10 border border-primary/30 rounded-full">
        <div class="size-2 bg-primary rounded-full animate-pulse"></div>
        <span class="text-[10px] font-bold text-primary uppercase tracking-widest font-mono">Live Preview</span>
      </div>
    </div>

    <div class="flex-1 p-8 overflow-y-auto custom-scrollbar">
      <div id="preview-content" class="text-slate-400 text-sm">
        <p class="mb-4">Select a tab to view content...</p>
      </div>
    </div>

    <!-- Footer Stats -->
    <div class="h-12 border-t border-primary/20 bg-background-dark/80 flex items-center justify-between px-6">
      <div class="flex gap-6">
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-bold text-primary/40 uppercase tracking-tighter">Sessions</span>
          <span class="text-xs font-mono text-slate-100" id="session-count">0</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-bold text-primary/40 uppercase tracking-tighter">Hours</span>
          <span class="text-xs font-mono font-bold text-primary" id="hours-count">0</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetTab = tab.getAttribute('data-tab');
        
        // Update tab styles
        tabs.forEach(t => {
          t.classList.remove('text-primary', 'border-b-2', 'border-primary');
          t.classList.add('text-slate-500');
        });
        tab.classList.remove('text-slate-500');
        tab.classList.add('text-primary', 'border-b-2', 'border-primary');

        // Update content visibility
        contents.forEach(content => {
          content.classList.add('hidden');
        });
        document.getElementById(`tab-${targetTab}`)?.classList.remove('hidden');
      });
    });
  });
</script>

<style>
  .tab-btn {
    border-bottom: 2px solid transparent;
  }
</style>


