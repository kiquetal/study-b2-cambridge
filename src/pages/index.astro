---
import Layout from '../layouts/Layout.astro';
import StudyForm from '../components/StudyForm';
import FillSession from '../components/FillSession';
import Dashboard from '../components/Dashboard';
import RecentSessions from '../components/RecentSessions';
---

<Layout title="B2 Cambridge Study Tracker">
  <!-- Full Width Container -->
  <div class="flex-1 flex flex-col overflow-hidden">
    <!-- Tab Navigation -->
    <div class="flex border-b border-primary/20 bg-background-dark/60">
      <button class="tab-btn flex-1 px-6 py-3 text-xs font-bold uppercase tracking-widest text-primary border-b-2 border-primary" data-tab="create">
        <span class="material-symbols-outlined text-sm mr-2 inline-block align-middle">add_circle</span>
        Create Session
      </button>
      <button class="tab-btn flex-1 px-6 py-3 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors" data-tab="fill">
        <span class="material-symbols-outlined text-sm mr-2 inline-block align-middle">edit</span>
        Fill Session
      </button>
      <button class="tab-btn flex-1 px-6 py-3 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors" data-tab="dashboard">
        <span class="material-symbols-outlined text-sm mr-2 inline-block align-middle">dashboard</span>
        Dashboard
      </button>
      <button class="tab-btn flex-1 px-6 py-3 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors" data-tab="history">
        <span class="material-symbols-outlined text-sm mr-2 inline-block align-middle">history</span>
        History
      </button>
    </div>

    <!-- Tab Content -->
    <div class="flex-1 overflow-hidden bg-black/40">
      <!-- Create Session Tab -->
      <div id="tab-create" class="tab-content h-full overflow-y-auto custom-scrollbar p-8">
        <div class="max-w-2xl mx-auto">
          <div class="mb-6">
            <h2 class="text-2xl font-bold text-slate-100 mb-2">Create Session</h2>
            <p class="text-sm text-slate-400">Set up a new study session (just title and source)</p>
          </div>
          <StudyForm client:load />
        </div>
      </div>

      <!-- Fill Session Tab -->
      <div id="tab-fill" class="tab-content hidden h-full overflow-hidden p-8">
        <FillSession client:load />
      </div>

      <!-- Dashboard Tab -->
      <div id="tab-dashboard" class="tab-content hidden h-full overflow-y-auto custom-scrollbar p-8">
        <div class="max-w-5xl mx-auto">
          <Dashboard client:load />
        </div>
      </div>

      <!-- History Tab -->
      <div id="tab-history" class="tab-content hidden h-full overflow-y-auto custom-scrollbar p-8">
        <div class="max-w-5xl mx-auto">
          <RecentSessions client:load />
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetTab = tab.getAttribute('data-tab');
        
        // Update tab styles
        tabs.forEach(t => {
          t.classList.remove('text-primary', 'border-b-2', 'border-primary');
          t.classList.add('text-slate-500');
        });
        tab.classList.remove('text-slate-500');
        tab.classList.add('text-primary', 'border-b-2', 'border-primary');

        // Update content visibility
        contents.forEach(content => {
          content.classList.add('hidden');
        });
        document.getElementById(`tab-${targetTab}`)?.classList.remove('hidden');
      });
    });
  });
</script>

<style>
  .tab-btn {
    border-bottom: 2px solid transparent;
  }
</style>
