---
import Layout from '../layouts/Layout.astro';
import StudyForm from '../components/StudyForm';
import Dashboard from '../components/Dashboard';
---

<Layout title="B2 Cambridge Study Tracker">
  <!-- Sidebar -->
  <aside class="w-80 border-r border-primary/20 flex flex-col bg-white dark:bg-background-dark/80 overflow-y-auto custom-scrollbar">
    <div class="p-6 border-b border-primary/20 bg-slate-50 dark:bg-zinc-900/50">
      <div class="flex items-center gap-3 mb-4">
        <div class="size-10 bg-neon-yellow rounded flex items-center justify-center text-black">
          <span class="material-symbols-outlined font-bold text-xl">folder_open</span>
        </div>
        <div>
          <h3 class="text-sm font-black uppercase text-slate-900 dark:text-white">B2 Cambridge</h3>
          <p class="text-[10px] text-slate-500 uppercase tracking-tighter">Study Archive v1.0</p>
        </div>
      </div>
    </div>
    
    <div class="p-6 flex-1">
      <StudyForm client:load />
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 flex flex-col overflow-hidden bg-white dark:bg-background-dark">
    <div class="px-8 py-4 border-b border-primary/20 bg-white dark:bg-black/40">
      <div class="flex items-center gap-2 text-[10px] uppercase font-bold tracking-widest text-slate-500 mb-1">
        <span>Vault</span>
        <span class="material-symbols-outlined text-[10px]">chevron_right</span>
        <span class="text-neon-yellow">Study Sessions</span>
      </div>
      <h1 class="text-3xl font-black text-slate-900 dark:text-white uppercase tracking-tighter">
        Session <span class="text-neon-yellow">Dashboard</span>
      </h1>
    </div>

    <div class="flex-1 overflow-y-auto p-8 custom-scrollbar">
      <div class="max-w-5xl mx-auto">
        <Dashboard client:load />
      </div>
    </div>
  </main>
</Layout>

