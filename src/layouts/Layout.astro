---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <title>{title}</title>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display antialiased overflow-hidden">
  <div class="flex h-screen w-full flex-col">
    <!-- Top Navigation -->
    <header class="flex items-center justify-between border-b border-primary/20 bg-background-dark px-6 py-3">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2 text-primary">
          <span class="material-symbols-outlined text-2xl font-bold">rocket_launch</span>
          <h2 class="text-lg font-bold tracking-widest uppercase neon-glow">The Forge</h2>
        </div>
        <div class="h-4 w-px bg-primary/30 mx-2"></div>
        <div class="flex flex-col">
          <span class="text-[10px] uppercase tracking-widest text-primary/60 font-bold">Module</span>
          <span class="text-xs font-bold text-slate-100 tracking-tight">B2 FIRST CAMBRIDGE / STUDY TRACKER</span>
        </div>
      </div>
      <div class="flex items-center gap-6">
        <div class="flex flex-col items-end">
          <span class="text-[10px] uppercase tracking-widest text-primary/60 font-bold">Mode</span>
          <span class="text-xs font-bold tracking-tight uppercase text-primary">High Intensity</span>
        </div>
        <div class="h-8 w-8 rounded-full border border-primary/30 flex items-center justify-center bg-primary/10">
          <span class="material-symbols-outlined text-sm text-primary">bolt</span>
        </div>
        <div class="flex gap-2 border-l border-primary/20 pl-6">
          <button class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-xl">settings</span>
          </button>
          <button class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-xl">history</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex flex-1 overflow-hidden border-t border-primary/10">
      <slot />
    </main>

    <!-- Bottom Status Bar -->
    <footer class="h-8 bg-background-dark border-t border-primary/20 flex items-center px-4 justify-between">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-1.5">
          <span class="material-symbols-outlined text-xs text-green-500">check_circle</span>
          <span class="text-[10px] text-primary/60 uppercase font-bold tracking-tight">Sync Status: Secure</span>
        </div>
        <div class="h-3 w-px bg-primary/20"></div>
        <div class="flex items-center gap-1.5">
          <span class="text-[10px] text-primary/60 uppercase font-bold tracking-tight">Focus Level:</span>
          <div class="flex gap-0.5">
            <div class="h-1.5 w-3 bg-primary/80 rounded-sm"></div>
            <div class="h-1.5 w-3 bg-primary/80 rounded-sm"></div>
            <div class="h-1.5 w-3 bg-primary/80 rounded-sm"></div>
            <div class="h-1.5 w-3 bg-primary/20 rounded-sm"></div>
          </div>
        </div>
      </div>
      <div class="text-[10px] font-mono text-primary/40">
        FORGE_V2.0.4_CAMBRIDGE_EDITION
      </div>
    </footer>
  </div>
</body>
</html>
